<Window x:Class="AIBridge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIBridge"
        xmlns:vm="clr-namespace:AIBridge.ViewModels"
        xmlns:conv="clr-namespace:AIBridge.Converters"
        xmlns:Tx="http://unclassified.software/source/txtranslation"
        xmlns:md="clr-namespace:MdXaml;assembly=MdXaml"
        mc:Ignorable="d"
        Title="{Tx:T 'DWN.Bridge - Local AI Agent'}" Height="662" Width="994"
        Background="#1E1E1E" Foreground="White"
        Icon="pack://application:,,,/aibridge.ico"
        Closing="Window_Closing">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:RemoveTripleBackticksConverter x:Key="RemoveTripleBackticksConverter" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <conv:InvertBooleanConverter x:Key="InvertBooleanConverter" />
        <conv:FileNameConverter x:Key="FileNameConverter" />
        <conv:IsImageFileConverter x:Key="IsImageFileConverter" />
        <conv:FilePathToImageConverter x:Key="FilePathToImageConverter" />
        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Background" Value="#1E1E1E" />
        </Style>
        <Style TargetType="{x:Type md:MarkdownScrollViewer}">
            <Setter Property="Foreground" Value="White" />
        </Style>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#1E1E1E" />


    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="55"/>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Agents and Workspace -->
        <Border Grid.Column="0" Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0" Width="{Binding LeftPanelWidth.Value}">
            <Grid Margin="10" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- AI Agents -->
                    <RowDefinition Height="150"/>
                    <!-- ListBox Agenti -->
                    <RowDefinition Height="Auto"/>
                    <!-- ComboBox SQL -->
                    <RowDefinition Height="Auto"/>
                    <!-- Titolo Workspace -->
                    <RowDefinition Height="*"/>
                    <!-- TreeView -->
                    <RowDefinition Height="Auto"/>
                    <!-- Footer Info/Account -->
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="{Tx:T AI Agents}" FontSize="18" FontWeight="Bold" Foreground="#4A90E2" VerticalAlignment="Center"
                               Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                               
                    <Button Grid.Column="2" Content="🤖 My Agents" Click="MyAgents_Click" 
                            Background="Transparent" Foreground="#A0A0A0" BorderThickness="0" Cursor="Hand" Padding="5,0" ToolTip="{Tx:T Manage My Agents}"
                            Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#7B68EE"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="3" Command="{Binding ToggleLeftPanelCommand}" Background="Transparent" Foreground="#4A90E2" BorderThickness="0" Cursor="Hand" Padding="5,0" ToolTip="Menu">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLeftPanelCollapsed}" Value="True">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="☰" FontSize="18"/>
                    </Button>
                </Grid>

                <ListBox Grid.Row="1" ItemsSource="{Binding AvailableAgents}" SelectedItem="{Binding SelectedAgent}"
         Background="Transparent" BorderThickness="0" Foreground="White" 
         ScrollViewer.VerticalScrollBarVisibility="Auto" 
         ScrollViewer.HorizontalScrollBarVisibility="Disabled" >
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#333337" CornerRadius="5" Margin="0,0,0,5" Padding="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding IconCode}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" Visibility="{Binding DataContext.IsLeftPanelCollapsed, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#A0A0A0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Selettore DB Contestuale (visibile solo se l'Agente è SQL) -->
                <StackPanel Grid.Row="2" Margin="0,10,0,5" Visibility="{Binding IsSqlAgentSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Tx:T Selected DB Profile:}" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,2"
                               Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <ComboBox ItemsSource="{Binding AvailableSqlProfiles}" SelectedItem="{Binding SelectedSqlProfile}" 
                              Padding="5" Margin="0,2,0,0" MinHeight="25">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <WrapPanel Grid.Row="3" Margin="0,10,0,10" VerticalAlignment="Center">
                    <TextBlock Text="{Tx:T Workspace}" FontSize="18" FontWeight="Bold" Foreground="#4A90E2" VerticalAlignment="Center" Margin="0,0,10,0"
                               Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    <Button Command="{Binding ChooseWorkspaceCommand}" Margin="2" Padding="5,2" Background="#333337" Foreground="White" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" ToolTip="{Tx:T Choose...}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" Width="18" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="{Tx:T Choose...}" Margin="5,0,0,0" Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding TestDbConnectionCommand}" Margin="2" Padding="5,2" Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="{Tx:T Test local DB connection}" VerticalAlignment="Center" Visibility="{Binding HasSqlProfiles, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔌" Width="18" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="{Tx:T Test DB}" Margin="5,0,0,0" Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditDbProfilesCommand}" Margin="2" Padding="5,2" Background="#2980B9" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="{Tx:T Edit DB Profiles}" VerticalAlignment="Center" Visibility="{Binding IsSqlAgentSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" Width="18" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Text="{Tx:T Edit DB}" Margin="5,0,0,0" Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <TreeView Grid.Row="4" ItemsSource="{Binding WorkspaceNodes}" Background="Transparent" BorderThickness="0" Foreground="White"
          x:Name="WorkspaceTreeView"
          PreviewMouseLeftButtonDown="WorkspaceTreeView_PreviewMouseLeftButtonDown"
          PreviewMouseMove="WorkspaceTreeView_PreviewMouseMove"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled" Visibility="{Binding IsLeftPanelCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,2" Background="Transparent" x:Name="NodePanel">
                                <TextBlock Text="{Binding Icon}" Margin="0,0,5,0" Foreground="LightGray" />
                                <TextBlock Text="{Binding Name}" Foreground="#E0E0E0" Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="{Tx:T Open folder/file location}" 
                                                      Command="{Binding PlacementTarget.Tag.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                      CommandParameter="{Binding PlacementTarget.DataContext.FullPath, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="{Tx:T Refresh directory}" 
                                                      Command="{Binding PlacementTarget.Tag.RefreshFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                                      Visibility="{Binding PlacementTarget.DataContext.IsDirectory, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=TreeView}}" CommandParameter="{Binding FullPath}" />
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <Button x:Name="RefreshBtn" Content="🔄" 
                                        Command="{Binding DataContext.RefreshFolderCommand, RelativeSource={RelativeSource AncestorType=TreeView}}" 
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Foreground="#A0A0A0" 
                                        Cursor="Hand" Padding="4,0" Margin="5,0,0,0"
                                        ToolTip="{Tx:T Refresh directory}"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                            <HierarchicalDataTemplate.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, ElementName=NodePanel}" Value="True" />
                                        <Condition Binding="{Binding IsDirectory}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter TargetName="RefreshBtn" Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </HierarchicalDataTemplate.Triggers>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <!-- Footer: User Account & Info -->
                <Grid Grid.Row="5" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="ⓘ" Click="ShowSplash_Click" 
                            Background="Transparent" Foreground="#A0A0A0" BorderThickness="0" 
                            FontSize="16" Cursor="Hand" ToolTip="{Tx:T About DWN.Bridge}" 
                            VerticalAlignment="Center" Padding="4,0" Margin="0,0,5,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#4A90E2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding AuthStatusText}" Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" FontStyle="Italic"/>
                        <Button Name="ManualGoogleLoginButton" Content="🌐" ToolTip="{Tx:T Manual Google Login (if blocked)}" Command="{Binding ManualGoogleLoginCommand}" Background="Transparent" Foreground="#A0A0A0" BorderThickness="0" Cursor="Hand" Padding="4,0" Margin="0,0,5,0"/>
                        <Button Name="LoginEmailButton" Content="✉️" ToolTip="{Tx:T Login with Email (Magic Link)}" Background="Transparent" Foreground="#A0A0A0" BorderThickness="0" Cursor="Hand" Padding="4,0" Click="LoginEmail_Click" Margin="0,0,5,0"/>
                        <Button Name="LoginButton" Content="🐙" ToolTip="{Tx:T Login with GitHub}" Background="Transparent" Foreground="#A0A0A0" BorderThickness="0" Cursor="Hand" Padding="4,0" Click="Login_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Center Panel: Chat Arena -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding SelectedAgent.Name, StringFormat='Active: {0}'}" FontSize="16" FontWeight="SemiBold" Foreground="#27AE60"/>
                
                <!-- Local Mode Banner -->
                <Border Grid.Column="1" Background="#B8860B" CornerRadius="4" Padding="8,4" 
                        Visibility="{Binding IsLocalMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding LocalModeBannerText}" FontWeight="Bold" Foreground="White" FontSize="12"/>
                </Border>
            </Grid>

            <!-- Chat History -->
            <ListBox x:Name="ChatListBox" Grid.Row="1" ItemsSource="{Binding ChatMessages}" 
                     SelectionMode="Extended"
                     Background="#1E1E1E" Foreground="White" BorderThickness="0" Margin="0,0,0,0" Padding="0,0,0,20"
                     HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.CanContentScroll="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="5,5,5,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <!-- Messaggio Tool Agentico -->
                            <Border Visibility="{Binding IsToolMessage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="#1A2332" CornerRadius="8" Padding="0" Margin="0,0,0,10"
                                BorderBrush="{Binding ToolBadgeColor}" BorderThickness="1,0,0,0">
                                <Border.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="White" />
                                    </Style>
                                    <Style TargetType="{x:Type Run}">
                                        <Setter Property="Foreground" Value="White" />
                                    </Style>
                                </Border.Resources>
                                <StackPanel>
                                    <!-- Header: nome tool e icona -->
                                    <Border Background="#0D1B2A" CornerRadius="8,8,0,0" Padding="10,7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="🔧 " FontSize="13"/>
                                                <TextBlock Text="{Binding ToolName}" FontSize="13" FontWeight="Bold"
                                                       Foreground="{Binding ToolBadgeColor}" Margin="4,0,0,0"/>
                                                <TextBlock Text="{Tx:T  — Tool Executed}" FontSize="11" Foreground="#607080" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsToolExpanded}"
                                                      Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                      Foreground="#607080" FontSize="11" Padding="6,2">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Content" Value="{Tx:T ▶ Details}"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Content" Value="{Tx:T ▼ Hide}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                        </Grid>
                                    </Border>

                                    <!-- Input (sempre visibile, compatto) -->
                                    <Border Padding="10,6,10,6" Background="#111C28">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▸ " Foreground="#607080" FontFamily="Consolas" FontSize="12"/>
                                            <TextBox Text="{Binding ToolInput, Mode=OneWay}" IsReadOnly="True"
                                                 TextWrapping="NoWrap" Background="Transparent" BorderThickness="0"
                                                 Foreground="#8BA0B8" FontFamily="Consolas" FontSize="12"
                                                 SelectionBrush="#4A90E2"
                                                 PreviewMouseLeftButtonDown="ChatTextBox_PreviewMouseLeftButtonDown"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Output collassabile -->
                                    <Border Padding="10,8" Background="#0A1520" CornerRadius="0,0,8,8"
                                        Visibility="{Binding IsToolExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="{Tx:T OUTPUT}" FontSize="9" Foreground="#607080" Margin="0,0,0,4" FontWeight="Bold"/>
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                                <TextBox Text="{Binding ToolOutput, Mode=OneWay}" IsReadOnly="True"
                                                     TextWrapping="NoWrap" Background="Transparent" BorderThickness="0"
                                                     Foreground="#7FEBA1" FontFamily="Consolas" FontSize="11"
                                                     SelectionBrush="#4A90E2"
                                                     PreviewMouseLeftButtonDown="ChatTextBox_PreviewMouseLeftButtonDown"/>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Messaggio Chat normale -->
                            <Border Visibility="{Binding IsToolMessage, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Background="{Binding BackgroundColor}" CornerRadius="8" Padding="10" 
                                HorizontalAlignment="{Binding Alignment}" Margin="0,0,0,10" MaxWidth="850">
                                <Border.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Foreground" Value="White" />
                                    </Style>
                                    <Style TargetType="{x:Type Run}">
                                        <Setter Property="Foreground" Value="White" />
                                    </Style>
                                </Border.Resources>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Header="{Tx:T Copy entire message}" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <StackPanel>
                                    <TextBlock Text="{Binding Sender}" FontSize="10" Foreground="#A0A0A0" Margin="0,0,0,5"/>
                                    <md:MarkdownScrollViewer Markdown="{Binding Text, Converter={StaticResource RemoveTripleBackticksConverter}, Mode=OneWay, TargetNullValue=' ', FallbackValue=' '}" 
                                         Background="Transparent" Foreground="White" 
                                         PreviewMouseLeftButtonDown="ChatTextBox_PreviewMouseLeftButtonDown"
                                         Loaded="MarkdownScrollViewer_Loaded">

                                        <md:MarkdownScrollViewer.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Header="{Tx:T Copy entire message}" />
                                                <MenuItem Command="ApplicationCommands.Copy" Header="{Tx:T Copy selected text}" />
                                            </ContextMenu>
                                        </md:MarkdownScrollViewer.ContextMenu>

                                        <md:MarkdownScrollViewer.Style>
                                            <Style TargetType="{x:Type md:MarkdownScrollViewer}">
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsCollapsible}" Value="True" />
                                                            <Condition Binding="{Binding IsExpanded}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="MaxHeight" Value="40" />
                                                        <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </md:MarkdownScrollViewer.Style>
                                    </md:MarkdownScrollViewer>
                                    <ToggleButton IsChecked="{Binding IsExpanded}" 
                                              Visibility="{Binding IsCollapsible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Margin="0,5,0,0" Padding="5,2" Background="Transparent" Foreground="#4A90E2" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Right">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Content" Value="{Tx:T Expand 🔽}" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Content" Value="{Tx:T Collapse 🔼}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>

                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Button Command="{Binding DataContext.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                            CommandParameter="{Binding}" 
                                            Content="{Tx:T 📋 Copy}" Padding="8,3" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Margin="0,0,5,0" />

                                        <Button Content="{Tx:T Open File in VS/Editor}" 
                                            Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                            CommandParameter="{Binding FilePathToOpen}" 
                                            Visibility="{Binding HasFile, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                            Padding="8,3" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand" />

                                        <Button Command="{Binding DataContext.ToggleFileRejectCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" 
                                            CommandParameter="{Binding}" 
                                            Visibility="{Binding HasBackup, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                            Margin="5,0,0,0" Padding="8,3" Foreground="White" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Content" Value="{Tx:T Reject Change}" />
                                                    <Setter Property="Background" Value="#E74C3C" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRejected}" Value="True">
                                                            <Setter Property="Content" Value="{Tx:T Restore Change}" />
                                                            <Setter Property="Background" Value="#3498DB" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>

                                    <!-- Visualizzazione Dati Tabellari SQL -->
                                    <Border Margin="0,10,0,0" Background="#1E1E1E" CornerRadius="5" Padding="10" 
                                        Visibility="{Binding IsSqlResult, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- Pulsanti di esportazione -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                <Button Content="{Tx:T 📋 Copy Text}" Command="{Binding DataContext.CopySqlTextCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"
                                                    Background="#34495E" Foreground="White" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                                                <Button Content="{Tx:T 📊 Copy for Excel}" Command="{Binding DataContext.CopySqlTsvCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"
                                                    Background="#27AE60" Foreground="White" Padding="8,4" Margin="10,0,0,0" BorderThickness="0" Cursor="Hand"/>
                                            </StackPanel>
                                            <!-- Output Terminal-like -->
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                                <TextBox Text="{Binding FormattedTableText, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" 
                                                     Background="Transparent" BorderThickness="0" Foreground="#00FF00" 
                                                     FontFamily="Consolas" FontSize="13" SelectionBrush="#4A90E2" SelectionTextBrush="White"
                                                     PreviewMouseLeftButtonDown="ChatTextBox_PreviewMouseLeftButtonDown">
                                                    <TextBox.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Command="ApplicationCommands.Copy" Header="{Tx:T 📋 Copy}" />
                                                        </ContextMenu>
                                                    </TextBox.ContextMenu>
                                                </TextBox>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Spinner di caricamento e attesa -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="10,5,0,10" 
                        Visibility="{Binding IsAnyBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding StatusMessage}" Foreground="#A0A0A0" FontStyle="Italic" VerticalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Width="80" Height="4" Margin="15,0,0,0" BorderThickness="0" Background="#2D2D30">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Foreground" Value="#4A90E2" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSqlBusy}" Value="True">
                                    <Setter Property="Foreground" Value="#E67E22" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </StackPanel>

            <!-- Input Area -->
            <Grid x:Name="InputAreaGrid" Grid.Row="3" Margin="0,0,0,0" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Area file allegati -->
                <ItemsControl Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" ItemsSource="{Binding AttachedFiles}" Margin="0,0,0,5">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2D2D30" CornerRadius="4" Padding="5,2" Margin="0,0,5,5" BorderBrush="#3F3F46" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <!-- Thumbnail miniatura per le immagini -->
                                    <Image x:Name="ThumbImg" Width="28" Height="28" Margin="0,0,4,0"
                                           Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Converter={StaticResource IsImageFileConverter}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Source" Value="{Binding Converter={StaticResource FilePathToImageConverter}}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}" FontSize="11" Foreground="#A0A0A0" MaxWidth="150" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Button Content="✕" Command="{Binding DataContext.RemoveAttachedFileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"
                                            Margin="5,0,0,0" Background="Transparent" Foreground="#E74C3C" BorderThickness="0" Cursor="Hand" ToolTip="{Tx:T Remove attached file}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBox x:Name="PromptTextBox" Grid.Row="1" Grid.Column="0" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#2D2D30" Foreground="White" BorderBrush="#3F3F46" 
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" MaxHeight="250" VerticalScrollBarVisibility="Auto" Padding="5"
                         PreviewKeyDown="PromptTextBox_PreviewKeyDown">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SendMessageCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="10,0,0,0">
                    <Button Content="{Tx:T Attach File}" Command="{Binding SelectFileCommand}"
                            Width="100" Height="25" Margin="0,0,0,5" Background="#5C5C5C" Foreground="White" BorderThickness="0"/>
                    <Grid>
                        <Button Content="{Tx:T Send to ChatBot}" Command="{Binding SendMessageCommand}"
                                Width="100" Height="30" Background="#4A90E2" Foreground="White" BorderThickness="0"
                                Visibility="{Binding IsAnyBusy, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <Button Content="{Tx:T Stop / Reset}" Command="{Binding ResetStateCommand}"
                                Width="100" Height="30" Background="#E74C3C" Foreground="White" BorderThickness="0"
                                Visibility="{Binding IsAnyBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,5,0,0" HorizontalAlignment="Left">
                    <Button Command="{Binding ReinjectSkillCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="{Tx:T Re-inject Agent Directives (System Prompt)}"
                            IsEnabled="{Binding IsAnyBusy, Converter={StaticResource InvertBooleanConverter}, FallbackValue=True}">
                        <StackPanel Orientation="Horizontal" Opacity="0.8">
                            <TextBlock Text="🔄" Margin="0,0,3,0" FontSize="14" Foreground="#A0A0A0"/>
                            <TextBlock Text="🧠" FontSize="14"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleTrainingModeCommand}" CommandParameter="{Binding ElementName=ChatListBox, Path=SelectedItems}" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="10,0,0,0"
                            IsEnabled="{Binding IsAnyBusy, Converter={StaticResource InvertBooleanConverter}, FallbackValue=True}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="ToolTip" Value="{Tx:T Start Training (Select messages)}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTrainingMode}" Value="True">
                                        <Setter Property="ToolTip" Value="{Tx:T Confirm Selection}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" Opacity="0.8">
                            <TextBlock FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="🎓" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTrainingMode}" Value="True">
                                                <Setter Property="Text" Value="✅" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="📖" FontSize="14" Margin="3,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#A0A0A0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTrainingMode}" Value="True">
                                                <Setter Property="Foreground" Value="#27AE60" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Tx:T Training phase in progress\, select one or more conversation sections}" 
                               VerticalAlignment="Center" Margin="10,0,0,0" FontStyle="Italic">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#E67E22" />
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTrainingMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Right Panel: Chat History -->
        <Border Grid.Column="2" Background="#1A1A2E" BorderBrush="#3F3F46" BorderThickness="1,0,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Language selector -->
                    <RowDefinition Height="Auto"/>
                    <!-- Buttons -->
                    <RowDefinition Height="*"/>
                    <!-- History list -->
                    <RowDefinition Height="Auto"/>
                    <!-- Status -->
                    <RowDefinition Height="Auto" MaxHeight="160"/>
                    <!-- Network Audit Log -->
                    <RowDefinition Height="Auto"/>
                    <!-- System buttons -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <TextBlock Grid.Row="0" Text="{Tx:T 📋 Chat History}" FontSize="14" FontWeight="Bold" 
                           Foreground="#7B68EE" Margin="0,0,0,8"/>

                <!-- Language Selector -->
                <ComboBox Grid.Row="1"
                          ItemsSource="{Binding AvailableLanguages}"
                          SelectedItem="{Binding SelectedLanguage}"
                          Height="26" Margin="0,0,0,6"
                          Background="#252545" Foreground="White"
                          BorderBrush="#4A4A6A" BorderThickness="1"
                          Padding="6,2">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" FontSize="12" Foreground="White"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.Style>
                        <Style TargetType="ComboBox">
                            <Setter Property="Background" Value="#252545"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderBrush" Value="#4A4A6A"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ComboBox">
                                        <Grid>
                                            <ToggleButton x:Name="ToggleButton"
                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                              Background="#252545" BorderBrush="#4A4A6A" BorderThickness="1"
                              Cursor="Hand" ClickMode="Press">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="24"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="1" Text="▾" Foreground="#7B68EE"
                                               VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>

                                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" 
                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource TemplatedParent}}"
                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource TemplatedParent}}"
                                  ContentTemplateSelector="{Binding ItemTemplateSelector, RelativeSource={RelativeSource TemplatedParent}}"
                                  Margin="8,2,24,2"
                                  VerticalAlignment="Center" HorizontalAlignment="Left"/>

                                            <Popup x:Name="Popup" IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                       Placement="Bottom" AllowsTransparency="True" Focusable="False">
                                                <Border Background="#1E1E2E" BorderBrush="#4A4A6A" BorderThickness="1" CornerRadius="4"
                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#7B68EE"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="8,4"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2D2D4E"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E3A5F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <!-- New Chat Button -->
                <Button Grid.Row="2" Content="{Tx:T ✨ New Chat}" Command="{Binding NewChatCommand}"
                        Height="30" Margin="0,0,0,8"
                        Background="#4A90E2" Foreground="White" BorderThickness="0"
                        Cursor="Hand"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}, FallbackValue=True}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4A90E2"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="5,3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#5BA3F5"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Chat History List -->
                <ListBox Grid.Row="3" x:Name="HistoryListBox"
                         ItemsSource="{Binding ChatHistory}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ToolTip="{Tx:T 'Double-click to continue from a saved conversation'}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Margin="0,0,0,4">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2D2D4E"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2D2D4E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6,5" CornerRadius="5"
                                    MouseLeftButtonDown="HistoryItem_MouseLeftButtonDown"
                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Stato inattivo: sfondo scuro, nessun bordo -->
                                        <Setter Property="Background" Value="#252545"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="#1E3A5F"/>
                                                <Setter Property="BorderBrush" Value="#4A90E2"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{Tx:T 📂 Open this chat}"
                                                  Command="{Binding PlacementTarget.Tag.LoadSessionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="{Tx:T ✏️ Rename chat}"
                                                  Command="{Binding PlacementTarget.Tag.RenameChatCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="{Tx:T 🔄 Sync chat name}"
                                                  Command="{Binding PlacementTarget.Tag.SyncChatNameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <MenuItem Header="{Tx:T Save current Agent and Workspace}"
                                                  Command="{Binding PlacementTarget.Tag.SaveCurrentAgentAndWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Separator/>
                                        <MenuItem Header="{Tx:T 🗑️ Delete from history}"
                                                  Command="{Binding PlacementTarget.Tag.DeleteSessionFromHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Agent + Active indicator -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding StorageIcon}" FontSize="10" 
                                                   Margin="0,0,4,0" FontFamily="Segoe UI Emoji"
                                                   Foreground="{Binding StorageIconColor}"/>
                                        <TextBlock Text="{Binding AgentName}" FontSize="10" 
                                                   Foreground="#7B68EE" FontWeight="Bold"/>
                                        <TextBlock Text=" ●" FontSize="10" Foreground="#4A90E2" 
                                                   Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <!-- Description: NoWrap è obbligatorio per TextTrimming=CharacterEllipsis -->
                                    <TextBlock Grid.Row="1" Text="{Binding DisplayDescription}" 
                                               FontSize="11" Foreground="#DCDCDC"
                                               TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,2"/>
                                    <!-- Date/time -->
                                    <TextBlock Grid.Row="2" Text="{Binding DisplayHeader}" 
                                               FontSize="9" Foreground="#6A6A8A"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Status Message -->
                <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Foreground="#A0A0A0" 
                           FontSize="10" TextWrapping="Wrap" FontStyle="Italic" Margin="0,5,0,5"/>

                <!-- Network Audit Log -->
                <Expander Grid.Row="5" Margin="0,0,0,4"
                          Header="🔒 Network Audit"
                          Foreground="#7B68EE" FontSize="11" FontWeight="Bold"
                          IsExpanded="False">
                    <Border Background="#12121E" CornerRadius="4" Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListBox Grid.Row="0" x:Name="AuditListBox"
                                     ItemsSource="{Binding AuditEntries}"
                                     MaxHeight="110" Background="Transparent" BorderThickness="0"
                                     Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="2,1"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}" Foreground="#666699" FontSize="9" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Direction}" FontSize="9" FontWeight="Bold" Margin="0,0,4,0" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#4A90E2"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Direction}" Value="-&gt; Server">
                                                                <Setter Property="Foreground" Value="#27AE60"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Summary}" FontSize="9" Foreground="#AAAACC" TextTrimming="CharacterEllipsis" MaxWidth="120" VerticalAlignment="Center"/>
                                            <TextBlock Text=" 🔒" FontSize="9" Foreground="#27AE60" VerticalAlignment="Center"
                                                       Visibility="{Binding IsEncrypted, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Grid.Row="1" Content="🗑 Clear" Command="{Binding ClearAuditLogCommand}"
                                    HorizontalAlignment="Right" Margin="0,3,0,0"
                                    Background="Transparent" Foreground="#E74C3C" BorderThickness="0"
                                    FontSize="10" Cursor="Hand"/>
                        </Grid>
                    </Border>
                </Expander>

                <!-- System Buttons -->
                <StackPanel Grid.Row="6">
                    <Button Content="{Tx:T ⚙ Start Browser}" Command="{Binding StartBrowserCommand}" 
                            Height="26" Margin="0,0,0,4" Background="#6A4C93" Foreground="White" BorderThickness="0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}, FallbackValue=True}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4,2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#7B5CA6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Command="{Binding ToggleWatcherCommand}" 
                            Height="26" Margin="0,0,0,4" Foreground="White" BorderThickness="0"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}, FallbackValue=True}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1E7A4E"/>
                                <Setter Property="Content" Value="{Tx:T 📁 Start Dir Watcher}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWatcherRunning}" Value="True">
                                        <Setter Property="Background" Value="#C0392B"/>
                                        <Setter Property="Content" Value="{Tx:T 🛑 Stop Dir Watcher}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="4,2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
