<Window x:Class="AIBridge.CaptchaWebViewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Google Security Check" Height="700" Width="500"
        WindowStyle="None" AllowsTransparency="True" Topmost="True"
        Background="Transparent" WindowStartupLocation="CenterScreen">
    <Border Background="#2D2D30" BorderBrush="#FF8C00" BorderThickness="2" CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="15">
                <TextBlock Text="Security Check Required" Foreground="#FF8C00" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                <TextBlock Text="Google richiede una rapida verifica di sicurezza. Completa il login o risolvi il CAPTCHA qui sotto per riprendere il lavoro dell'agente." Foreground="White" TextWrapping="Wrap" FontSize="13"/>
            </StackPanel>
            
            <wv2:WebView2 x:Name="webView" Grid.Row="1" Margin="10,0,10,10"/>
        </Grid>
    </Border>
</Window>
