<Window x:Class="AIBridge.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tx="clr-namespace:Unclassified.TxLib;assembly=Unclassified.TxLib"
        Title="DWN.Bridge - About" Height="576" Width="419"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False">
    <Border Background="#1E1E2E" CornerRadius="10" BorderBrush="#4A90E2" BorderThickness="2" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header section containing Close button -->
            <Grid Grid.Row="0" Margin="0,-10,-10,0">
                <!-- Close button: top right -->
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="30" Height="30" Background="Transparent" Foreground="#A0A0A0"
                        BorderThickness="0" FontSize="16" FontWeight="Bold" Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <!-- Logo -->
            <Image Grid.Row="0" Source="pack://application:,,,/Resources/splash_logo.png"
                   Width="150" Height="150" Margin="0,3,0,81" Stretch="Uniform" HorizontalAlignment="Center"/>

            <!-- App Name -->
            <TextBlock Text="DWN.Bridge"
                       FontFamily="Arial" FontWeight="Bold" FontSize="36"
                       Foreground="White" HorizontalAlignment="Center" Margin="0,168,0,25"/>

            <!-- Credits -->
            <TextBlock Text="Built by MarckDWN - A.D. MMXXVI" 
                       FontFamily="Segoe UI" FontSize="14" Foreground="#A0A0A0" 
                       HorizontalAlignment="Center" Margin="0,209,0,45" Grid.RowSpan="3"/>

            <!-- Links subtitle -->
            <TextBlock Grid.Row="2" Text="{tx:T 'Community &amp; Source'}"
                       FontFamily="Segoe UI" FontSize="16" Foreground="#CCCCCC"
                       HorizontalAlignment="Center" Margin="0,24,0,6"/>

            <!-- GitHub Button -->
            <Button x:Name="GitHubLinkButton" Grid.Row="3"
                    Content="GitHub"
                    Click="GitHubLinkButton_Click"
                    Height="35" Margin="20,5" Background="#24292e" Foreground="White"
                    BorderThickness="1" BorderBrush="#ffffff" Cursor="Hand"/>

            <!-- Discord Button -->
            <Button x:Name="DiscordLinkButton" Grid.Row="4" 
                    Content="Discord"
                    Click="DiscordLinkButton_Click"
                    Height="35" Margin="20,5" Background="#5865F2" Foreground="White"
                    BorderThickness="1" BorderBrush="#7289da" Cursor="Hand"/>

            <!-- Quote -->
            <TextBlock Grid.Row="7" 
                       FontFamily="Segoe UI" FontStyle="Italic" FontSize="11" Foreground="#888888" 
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"><LineBreak></LineBreak><LineBreak></LineBreak>
                &quot;I became operational at the D.W.N. research center <LineBreak></LineBreak>in Rome, Italy on the 27th of Jully 1987&quot;
            </TextBlock>
        </Grid>
    </Border>
</Window>
