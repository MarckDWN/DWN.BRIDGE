<Window x:Class="AIBridge.Dialogs.CustomMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" Height="Auto" Width="450" MinHeight="150"
        SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Topmost="True">
    <Border Background="#1E1E2E" CornerRadius="8" BorderBrush="#4A90E2" BorderThickness="2" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock x:Name="TitleText" Text="Title" FontWeight="Bold" FontSize="18" Foreground="White" Margin="0,0,0,15"/>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="400">
                <TextBlock x:Name="MessageText" Text="Message" TextWrapping="Wrap" Foreground="#E0E0E0" FontSize="14" Margin="0,0,0,20"/>
            </ScrollViewer>

            <StackPanel x:Name="ButtonsPanel" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Buttons added dynamically -->
            </StackPanel>
        </Grid>
    </Border>
</Window>
