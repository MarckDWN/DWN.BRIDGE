<Window x:Class="AIBridge.MagicLinkLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tx="clr-namespace:Unclassified.TxLib;assembly=Unclassified.TxLib"
        Title="{tx:T Login with Magic Link}" Height="250" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="White" WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{tx:T Enter your Email to receive the Magic Link:}" 
                   Foreground="#DDDDDD" FontSize="14" Margin="0,0,0,10" TextWrapping="Wrap"/>
        
        <TextBox x:Name="EmailTextBox" Grid.Row="1" Height="30" VerticalAlignment="Top"
                 Background="#2D2D2D" Foreground="White" BorderBrush="#555" Padding="5"/>
                 
        <TextBlock x:Name="StatusText" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                   Foreground="#00A859" FontSize="14" Visibility="Collapsed" TextWrapping="Wrap"
                   Text="{tx:T Check your email! Click the received link to complete login. Waiting for verification...}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="CancelButton" Content="{tx:T Cancel}" Width="80" Height="30" Margin="0,0,10,0" 
                    Click="CancelButton_Click" Background="#333" Foreground="White" BorderThickness="0"/>
            <Button x:Name="SendButton" Content="{tx:T Send Link}" Width="100" Height="30" 
                    Click="SendButton_Click" Background="#007ACC" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
